---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Simulation"
  description="Planned simulation tools for PE Toolbox PULSE workflows."
  pathname="/simulation/"
>
  <main class="page-shell category-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Simulation</span>
    </nav>
    <section aria-labelledby="simulation-title">
      <h1 id="simulation-title">Simulation</h1>
      <p>Simulation will introduce the PULSE workflow for schematic entry, solving, and waveform inspection.</p>
      <div class="status-card-grid">
        <article class="status-card"><strong>PULSE Studio</strong><span>Planned</span></article>
        <article class="status-card"><strong>PULSE Schematic</strong><span>Planned</span></article>
        <article class="status-card"><strong>PULSE Solver</strong><span>Planned</span></article>
        <article class="status-card"><strong>PULSE Scope</strong><span>Planned</span></article>
      </div>
    </section>
  </main>
</BaseLayout>
