---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/ToolCard.astro';
import { getToolsByCategory } from '@/data/tools';

const tools = getToolsByCategory('topology');
---

<BaseLayout
  title="Topology Designers"
  description="Power converter topology design tools planned for PE Toolbox."
  pathname="/topology-designers/"
>
  <main class="page-shell category-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Topology Designers</span>
    </nav>
    <section aria-labelledby="topology-title">
      <h1 id="topology-title">Topology Designers</h1>
      <p>Design workflows for common power converter topologies will be collected here, including Buck, Boost, Boost PFC, Flyback, and LLC converters.</p>
      <div class="tool-card-grid tool-card-grid--category">
        {tools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  </main>
</BaseLayout>
