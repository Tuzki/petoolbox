---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Topology Designers"
  description="Power converter topology design tools planned for PE Toolbox."
  pathname="/topology-designers/"
>
  <main class="page-shell category-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Topology Designers</span>
    </nav>
    <section aria-labelledby="topology-title">
      <h1 id="topology-title">Topology Designers</h1>
      <p>Design workflows for common power converter topologies will be collected here, including Buck, Boost, Boost PFC, Flyback, and LLC converters.</p>
      <div class="status-card-grid">
        <article class="status-card"><strong>Buck Converter Designer</strong><span>Planned</span></article>
        <article class="status-card"><strong>Boost Converter Designer</strong><span>Planned</span></article>
        <article class="status-card"><strong>Boost PFC Designer</strong><span>Planned</span></article>
        <article class="status-card"><strong>Flyback Converter Designer</strong><span>Planned</span></article>
        <article class="status-card"><strong>LLC Resonant Converter Designer</strong><span>Planned</span></article>
      </div>
    </section>
  </main>
</BaseLayout>
