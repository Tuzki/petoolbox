---
import ToolCard from '@/components/ToolCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getToolsByCategory } from '@/data/tools';

const tools = getToolsByCategory('calculators');
---

<BaseLayout
  title="Engineering Calculators"
  description="Power electronics engineering calculators for quick design checks."
  pathname="/tools/"
>
  <main class="page-shell category-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Engineering Calculators</span>
    </nav>
    <section aria-labelledby="tools-title">
      <h1 id="tools-title">Engineering Calculators</h1>
      <p>PE Toolbox will provide practical electrical and power-stage calculators for fast engineering checks.</p>
      <div class="tool-card-grid tool-card-grid--category">
        {tools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  </main>
</BaseLayout>
