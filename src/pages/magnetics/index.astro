---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/ToolCard.astro';
import { getToolsByCategory } from '@/data/tools';

const tools = getToolsByCategory('magnetics');
---

<BaseLayout
  title="Magnetics Design"
  description="Planned magnetics design tools for inductors and transformers."
  pathname="/magnetics/"
>
  <main class="page-shell category-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Magnetics Design</span>
    </nav>
    <section aria-labelledby="magnetics-title">
      <h1 id="magnetics-title">Magnetics Design</h1>
      <p>Magnetics design tools will cover inductor and transformer workflows used in power electronics converters.</p>
      <div class="tool-card-grid tool-card-grid--category">
        {tools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  </main>
</BaseLayout>
