---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';
---

<BaseLayout title={site.name} description={site.tagline} pathname="/">
  <main class="home-shell placeholder-shell">
    <section class="home-intro" aria-labelledby="home-title">
      <h1 id="home-title">PE Toolbox</h1>
      <p>Practical tools for power electronics engineers.</p>
      <p class="muted">The website is currently under private development.</p>
    </section>
  </main>
</BaseLayout>
