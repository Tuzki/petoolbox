---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getMessages } from '@/lib/i18n/messages';
import { getLocalizedPath } from '@/lib/i18n/routes';
import type { Locale } from '@/lib/i18n/config';

type Props = { locale: Locale };
const { locale } = Astro.props;
const t = getMessages(locale).pages.notFound;
---

<BaseLayout title={t.title} description={t.description} pathname="/404/" locale={locale}>
  <main class="page-shell">
    <section class="not-found" aria-labelledby="not-found-title">
      <h1 id="not-found-title">{t.h1}</h1>
      <p>{t.text}</p>
      <a class="button-link" href={getLocalizedPath('/', locale)}>{t.action}</a>
    </section>
  </main>
</BaseLayout>
