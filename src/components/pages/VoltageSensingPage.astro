---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  TARGET_ADC_UTILIZATION,
  calculateVoltageSensingDesign,
  formatCurrent,
  formatPower,
  formatResistance,
  formatResolution,
  formatVoltage,
  resistorPackageRatings,
  type VoltageSensingInputs
} from '@/lib/voltageSensing';
import type { Locale } from '@/lib/i18n/config';
import { getMessages } from '@/lib/i18n/messages';

type Props = { locale: Locale };
const { locale } = Astro.props;
const tool = getMessages(locale).tools.items['voltage-sensing-adc-scaling'];
const defaultInputs: VoltageSensingInputs = {
  maximumInputVoltage: 800,
  adcReferenceVoltage: 2.5,
  adcResolutionBits: 10,
  resistorSeries: 'E24',
  resistorSize: '0805',
  upperResistorCount: 6,
  topology: 'single-lower'
};

const defaultResult = calculateVoltageSensingDesign(defaultInputs);
const defaultOverallStatusCode = defaultResult.checks.some((check) => check.status === 'fail')
  ? 'fail'
  : defaultResult.checks.some((check) => check.status === 'review')
    ? 'review'
    : 'pass';
const defaultOverallStatus = locale === 'zh'
  ? ({ pass: '通过', review: '复核', fail: '失败' } as const)[defaultOverallStatusCode]
  : ({ pass: 'Pass', review: 'Review', fail: 'Fail' } as const)[defaultOverallStatusCode];
const description = tool.description;
const vt = locale === 'zh' ? {
  category: '工程计算工具',
  intro: '选择适合高压采样的实用分压器，并计算对应的 ADC 换算、分辨率、电流、功耗和元件应力。',
  target: '目标 ADC 利用率',
  inputs: '输入',
  vin: '最大输入电压',
  vref: 'ADC 参考电压',
  resolution: 'ADC 分辨率',
  series: '电阻系列',
  size: '电阻封装',
  upperCount: '上臂串联电阻数量',
  topology: '分压拓扑',
  oneLower: '1 个下臂',
  oneLowerHint: '一个下臂电阻',
  twoLower: '2 个下臂并联',
  twoLowerHint: '两个相同下臂电阻并联',
  upperNote: '上臂为一串高压电阻。在并联模式下，两个下臂电阻取值相同，等效电阻减半。',
  searchNote: '电阻搜索偏向实用的下臂阻值，以平衡 ADC 源阻抗和分压功耗。',
  calculated: '计算结果',
  combination: '标准电阻组合',
  upperString: '推荐上臂电阻串',
  lowerBranch: '推荐下臂电阻支路',
  seriesTotal: '串联总值',
  equivalent: '等效电阻',
  parallelEquivalent: '并联等效',
  adcUsed: 'ADC 量程使用',
  scaling: '换算比例',
  fit: '标准值匹配',
  deviation: '相对目标偏差',
  inputResolution: '输入分辨率',
  dividerCurrent: '分压电流',
  dividerPower: '分压功耗',
  fitNote: '标准值匹配只表示所选 E24 或 E96 电阻组合接近 90% ADC 利用率目标的程度，不包含电阻容差、温度系数、ADC 误差或参考电压误差。',
  engineering: '工程校核',
  firmware: '固件换算',
  conversion: '输入电压换算',
  copy: '复制',
  ratingNote: '这里的封装额定值只用于初步筛选。请始终根据制造商数据手册核对所选电阻料号、工作电压、脉冲额定值、功率降额、温升和爬电距离要求。当前典型',
  values: '值'
} : {
  category: 'Engineering Calculators',
  intro: 'Select a practical resistor divider for high-voltage sensing and calculate the corresponding ADC scaling, resolution, current, power, and component stress.',
  target: 'Target ADC utilization',
  inputs: 'Inputs',
  vin: 'Maximum Input Voltage',
  vref: 'ADC Reference Voltage',
  resolution: 'ADC Resolution',
  series: 'Resistor Series',
  size: 'Resistor Size',
  upperCount: 'Number of Series Upper Resistors',
  topology: 'Divider Topology',
  oneLower: '1 Lower',
  oneLowerHint: 'One lower resistor',
  twoLower: '2 Lower in Parallel',
  twoLowerHint: 'Two identical lower resistors in parallel',
  upperNote: 'The upper side is one high-voltage resistor string. In the parallel mode, the two lower resistors have the same value and create half the equivalent resistance.',
  searchNote: 'The resistor search favors a practical lower resistance to balance ADC source impedance and divider power.',
  calculated: 'Calculated Design',
  combination: 'Standard resistor combination',
  upperString: 'Recommended Upper Resistor String',
  lowerBranch: 'Recommended Lower Resistor Branch',
  seriesTotal: 'Series total',
  equivalent: 'Equivalent resistance',
  parallelEquivalent: 'Parallel equivalent',
  adcUsed: 'ADC Range Used',
  scaling: 'Scaling Ratio',
  fit: 'Standard-Value Fit',
  deviation: 'Deviation from target',
  inputResolution: 'Input Resolution',
  dividerCurrent: 'Divider Current',
  dividerPower: 'Divider Power',
  fitNote: 'Standard-value fit only indicates how closely the selected E24 or E96 resistor combination matches the 90% ADC utilization target. It does not include resistor tolerance, temperature coefficient, ADC error, or reference-voltage error.',
  engineering: 'Engineering Check',
  firmware: 'Firmware Scaling',
  conversion: 'Input voltage conversion',
  copy: 'Copy',
  ratingNote: 'Package ratings shown here are typical values for preliminary screening only. Always verify the selected resistor part number, working voltage, pulse rating, power derating, temperature rise, and creepage requirements from the manufacturer datasheet. Current typical',
  values: 'values'
};
const checkLabels = {
  en: {
    'adc-headroom': 'ADC headroom',
    'upper-voltage': 'Upper resistor voltage stress',
    'upper-power': 'Upper resistor power',
    'lower-power': 'Lower resistor power'
  },
  zh: {
    'adc-headroom': 'ADC 裕量',
    'upper-voltage': '上臂电阻耐压应力',
    'upper-power': '上臂电阻功耗',
    'lower-power': '下臂电阻功耗'
  }
} as const;
function renderCheckDetail(check: (typeof defaultResult.checks)[number]) {
  const value = check.values;
  if (check.messageCode === 'adc-headroom') return locale === 'zh'
    ? `最大输入时 ADC 电压为 ${formatVoltage(Number(value.adcVoltage))}，使用 ADC 量程的 ${(Number(value.adcUtilization) * 100).toFixed(1)}%。`
    : `${formatVoltage(Number(value.adcVoltage))} at maximum input, using ${(Number(value.adcUtilization) * 100).toFixed(1)}% of the ADC range.`;
  if (check.messageCode === 'upper-voltage') return locale === 'zh'
    ? `每个上臂电阻承受 ${formatVoltage(Number(value.upperVoltageEachV))}；典型 ${value.resistorSize} 初筛耐压为 ${value.workingVoltageV} V。`
    : `${formatVoltage(Number(value.upperVoltageEachV))} per upper resistor; typical ${value.resistorSize} screening value is ${value.workingVoltageV} V.`;
  if (check.messageCode === 'upper-power') return locale === 'zh'
    ? `每个上臂电阻功耗 ${formatPower(Number(value.upperPowerEachW))}；典型 ${value.resistorSize} 初筛功率为 ${formatPower(Number(value.powerW))}。`
    : `${formatPower(Number(value.upperPowerEachW))} per upper resistor; typical ${value.resistorSize} screening value is ${formatPower(Number(value.powerW))}.`;
  return locale === 'zh'
    ? `每个下臂电阻功耗 ${formatPower(Number(value.lowerPowerEachW))}。分压电流为 ${formatCurrent(Number(value.dividerCurrentA))}。`
    : `${formatPower(Number(value.lowerPowerEachW))} per lower resistor. Divider current is ${formatCurrent(Number(value.dividerCurrentA))}.`;
}
---

<BaseLayout
  title={tool.title}
  description={description}
  pathname="/tools/voltage-sensing-adc-scaling/"
  locale={locale}
>
  <main class="page-shell tool-workbench">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={`/${locale}/`}>{getMessages(locale).site.breadcrumbs.home}</a>
      <span aria-hidden="true">/</span>
      <a href={`/${locale}/tools/`}>{getMessages(locale).navigation.items['engineering-calculators']}</a>
      <span aria-hidden="true">/</span>
      <span>{tool.title}</span>
    </nav>

    <header class="tool-workbench__header">
      <div>
        <p class="section-eyebrow">{vt.category}</p>
        <h1>{tool.title}</h1>
        <p>{vt.intro}</p>
      </div>
      <div class="tool-workbench__target">{vt.target}: {TARGET_ADC_UTILIZATION * 100}%</div>
    </header>

    <div class="tool-workbench__layout" data-voltage-sensing-tool data-locale={locale}>
      <section class="tool-input-panel" aria-labelledby="voltage-sensing-inputs">
        <h2 id="voltage-sensing-inputs">{vt.inputs}</h2>
        <div class="tool-field">
          <label for="maximum-input-voltage">{vt.vin}</label>
          <div class="tool-control">
            <input id="maximum-input-voltage" data-input="maximumInputVoltage" type="number" min="0.1" step="1" value={defaultInputs.maximumInputVoltage} />
            <span>V</span>
          </div>
          <p class="tool-field__error" data-error-for="maximumInputVoltage" hidden></p>
        </div>

        <div class="tool-field">
          <label for="adc-reference-voltage">{vt.vref}</label>
          <div class="tool-control">
            <input id="adc-reference-voltage" data-input="adcReferenceVoltage" type="number" min="0.1" step="0.1" value={defaultInputs.adcReferenceVoltage} />
            <span>V</span>
          </div>
          <p class="tool-field__error" data-error-for="adcReferenceVoltage" hidden></p>
        </div>

        <div class="tool-field">
          <label for="adc-resolution">{vt.resolution}</label>
          <div class="tool-control tool-control--select">
            <select id="adc-resolution" data-input="adcResolutionBits">
              <option value="8">8-bit</option>
              <option value="10" selected>10-bit</option>
              <option value="12">12-bit</option>
              <option value="14">14-bit</option>
            </select>
          </div>
        </div>

        <div class="tool-field">
          <label for="resistor-series">{vt.series}</label>
          <div class="tool-control tool-control--select">
            <select id="resistor-series" data-input="resistorSeries">
              <option value="E24" selected>E24</option>
              <option value="E96">E96</option>
            </select>
          </div>
        </div>

        <div class="tool-field">
          <label for="resistor-size">{vt.size}</label>
          <div class="tool-control tool-control--select">
            <select id="resistor-size" data-input="resistorSize">
              <option value="0402">0402</option>
              <option value="0603">0603</option>
              <option value="0805" selected>0805</option>
              <option value="1206">1206</option>
              <option value="1210">1210</option>
            </select>
          </div>
        </div>

        <div class="tool-field">
          <label for="upper-resistor-count">{vt.upperCount}</label>
          <div class="tool-control">
            <input id="upper-resistor-count" data-input="upperResistorCount" type="number" min="1" max="30" step="1" value={defaultInputs.upperResistorCount} />
            <span>pcs</span>
          </div>
          <p class="tool-field__error" data-error-for="upperResistorCount" hidden></p>
        </div>

        <fieldset class="tool-field tool-segmented" data-input="topology">
          <legend>{vt.topology}</legend>
          <label>
            <input type="radio" name="topology" value="single-lower" checked />
            <span>{vt.oneLower}</span>
            <small>{vt.oneLowerHint}</small>
          </label>
          <label>
            <input type="radio" name="topology" value="parallel-lower" />
            <span>{vt.twoLower}</span>
            <small>{vt.twoLowerHint}</small>
          </label>
        </fieldset>

        <p class="tool-note">
          {vt.upperNote}
        </p>
        <p class="tool-note">
          {vt.searchNote}
        </p>
      </section>

      <section class="tool-results" aria-live="polite">
        <article class="tool-result-card tool-result-card--primary">
          <div class="tool-result-card__heading">
            <div>
              <p class="category-eyebrow">{vt.calculated}</p>
              <h2>{vt.combination}</h2>
            </div>
            <span class:list={['tool-check-pill', `tool-check-pill--${defaultOverallStatusCode}`]} data-output="overallStatus">{defaultOverallStatus}</span>
          </div>

          <div class="resistor-recommendation">
            <div>
              <span>{vt.upperString}</span>
              <strong data-output="upperString">{defaultInputs.upperResistorCount} × {formatResistance(defaultResult.upperEachOhms)}</strong>
              <small data-output="upperDetail">{vt.seriesTotal}: {formatResistance(defaultResult.upperTotalOhms)}</small>
            </div>
            <div>
              <span>{vt.lowerBranch}</span>
              <strong data-output="lowerBranch">1 × {formatResistance(defaultResult.lowerEachOhms)}</strong>
              <small data-output="lowerDetail">{vt.equivalent}: {formatResistance(defaultResult.lowerEquivalentOhms)}</small>
            </div>
          </div>

          <div class="conversion-flow" aria-label="Conversion flow">
            <strong data-output="flowInput">{formatVoltage(defaultInputs.maximumInputVoltage)}</strong>
            <span aria-hidden="true">→</span>
            <strong data-output="flowAdc">{defaultResult.adcVoltage.toFixed(3)} V ADC</strong>
            <span aria-hidden="true">→</span>
            <strong data-output="flowCode">{defaultResult.adcCode} / {defaultResult.adcMaxCode}</strong>
          </div>

          <div class="metric-grid">
            <div class="metric-tile">
              <span>{vt.adcUsed}</span>
              <strong data-output="adcUtilization">{(defaultResult.adcUtilization * 100).toFixed(1)}%</strong>
            </div>
            <div class="metric-tile">
              <span>{vt.scaling}</span>
              <strong data-output="scalingRatio">{defaultResult.scalingRatio.toFixed(1)} : 1</strong>
            </div>
            <div class="metric-tile">
              <span>{vt.fit}</span>
              <strong data-output="nominalAccuracy">{defaultResult.nominalAccuracyPercent.toFixed(3)}%</strong>
              <small data-output="valueFitError">{vt.deviation}: {defaultResult.valueFitErrorPercent >= 0 ? '+' : ''}{defaultResult.valueFitErrorPercent.toFixed(3)}%</small>
            </div>
            <div class="metric-tile">
              <span>{vt.inputResolution}</span>
              <strong data-output="inputResolution">{formatResolution(defaultResult.inputResolutionVPerCount)}</strong>
            </div>
            <div class="metric-tile">
              <span>{vt.dividerCurrent}</span>
              <strong data-output="dividerCurrent">{formatCurrent(defaultResult.dividerCurrentA)}</strong>
            </div>
            <div class="metric-tile">
              <span>{vt.dividerPower}</span>
              <strong data-output="dividerPower">{formatPower(defaultResult.dividerPowerW)}</strong>
            </div>
          </div>

          <p class="tool-note">
            {vt.fitNote}
          </p>
        </article>

        <div class="tool-results__bottom">
          <article class="tool-result-card">
            <h2>{vt.engineering}</h2>
            <div class="engineering-checks" data-output="checks">
              {defaultResult.checks.map((check) => (
                <div class:list={['engineering-check', `engineering-check--${check.status}`]}>
                  <span>{check.status}</span>
                  <div>
                    <strong>{checkLabels[locale][check.messageCode]}</strong>
                    <p>{renderCheckDetail(check)}</p>
                  </div>
                </div>
              ))}
            </div>
            <p class="tool-warning" data-output="ratingNote">
              {vt.ratingNote} {defaultInputs.resistorSize} {vt.values}:
              {formatPower(resistorPackageRatings[defaultInputs.resistorSize].powerW)} and {resistorPackageRatings[defaultInputs.resistorSize].workingVoltageV} V.
            </p>
          </article>

          <article class="tool-result-card">
            <h2>{vt.firmware}</h2>
            <p data-output="formulaText">
              {vt.conversion}: Vin = ADC code × {defaultResult.inputResolutionVPerCount.toFixed(8)} V.
            </p>
            <div class="code-panel">
              <button class="button-link button-link--secondary code-panel__copy" type="button" data-copy-code>{vt.copy}</button>
              <code data-output="firmwareCode">{defaultResult.firmwareCode}</code>
            </div>
          </article>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<script>
  import {
    calculateVoltageSensingDesign,
    formatCurrent,
    formatPower,
    formatResistance,
    formatResolution,
    formatVoltage,
    resistorPackageRatings
  } from '@/lib/voltageSensing';

    const root = document.querySelector<HTMLElement>('[data-voltage-sensing-tool]');

    if (root) {
    const locale = root.dataset.locale === 'zh' ? 'zh' : 'en';
    const textLabels = {
      en: {
        pass: 'Pass',
        review: 'Review',
        fail: 'Fail',
        upperTotal: 'Series total',
        equivalent: 'Equivalent resistance',
        parallelEquivalent: 'Parallel equivalent',
        deviation: 'Deviation from target',
        conversion: 'Input voltage conversion',
        ratingNote: 'Package ratings shown here are typical values for preliminary screening only. Always verify the selected resistor part number, working voltage, pulse rating, power derating, temperature rise, and creepage requirements from the manufacturer datasheet. Current typical',
        values: 'values',
        vinError: 'Enter a voltage greater than 0 V.',
        vrefError: 'Enter a reference voltage greater than 0 V.',
        countError: 'Enter an integer from 1 to 30.',
        noCombination: 'No practical standard-value combination was found for these inputs.',
        copied: 'Copied',
        copyFailed: 'Copy failed',
        copy: 'Copy'
      },
      zh: {
        pass: '通过',
        review: '复核',
        fail: '失败',
        upperTotal: '串联总值',
        equivalent: '等效电阻',
        parallelEquivalent: '并联等效',
        deviation: '相对目标偏差',
        conversion: '输入电压换算',
        ratingNote: '这里的封装额定值只用于初步筛选。请始终根据制造商数据手册核对所选电阻料号、工作电压、脉冲额定值、功率降额、温升和爬电距离要求。当前典型',
        values: '值',
        vinError: '请输入大于 0 V 的电压。',
        vrefError: '请输入大于 0 V 的参考电压。',
        countError: '请输入 1 到 30 之间的整数。',
        noCombination: '这些输入下未找到实用的标准阻值组合。',
        copied: '已复制',
        copyFailed: '复制失败',
        copy: '复制'
      }
    } as const;
    const checkLabels = {
      en: {
        'adc-headroom': 'ADC headroom',
        'upper-voltage': 'Upper resistor voltage stress',
        'upper-power': 'Upper resistor power',
        'lower-power': 'Lower resistor power'
      },
      zh: {
        'adc-headroom': 'ADC 裕量',
        'upper-voltage': '上臂电阻耐压应力',
        'upper-power': '上臂电阻功耗',
        'lower-power': '下臂电阻功耗'
      }
    } as const;
    const renderCheckDetail = (check: ReturnType<typeof calculateVoltageSensingDesign>['checks'][number]) => {
      const value = check.values;
      if (check.messageCode === 'adc-headroom') return locale === 'zh'
        ? `最大输入时 ADC 电压为 ${formatVoltage(Number(value.adcVoltage))}，使用 ADC 量程的 ${(Number(value.adcUtilization) * 100).toFixed(1)}%。`
        : `${formatVoltage(Number(value.adcVoltage))} at maximum input, using ${(Number(value.adcUtilization) * 100).toFixed(1)}% of the ADC range.`;
      if (check.messageCode === 'upper-voltage') return locale === 'zh'
        ? `每个上臂电阻承受 ${formatVoltage(Number(value.upperVoltageEachV))}；典型 ${value.resistorSize} 初筛耐压为 ${value.workingVoltageV} V。`
        : `${formatVoltage(Number(value.upperVoltageEachV))} per upper resistor; typical ${value.resistorSize} screening value is ${value.workingVoltageV} V.`;
      if (check.messageCode === 'upper-power') return locale === 'zh'
        ? `每个上臂电阻功耗 ${formatPower(Number(value.upperPowerEachW))}；典型 ${value.resistorSize} 初筛功率为 ${formatPower(Number(value.powerW))}。`
        : `${formatPower(Number(value.upperPowerEachW))} per upper resistor; typical ${value.resistorSize} screening value is ${formatPower(Number(value.powerW))}.`;
      return locale === 'zh'
        ? `每个下臂电阻功耗 ${formatPower(Number(value.lowerPowerEachW))}。分压电流为 ${formatCurrent(Number(value.dividerCurrentA))}。`
        : `${formatPower(Number(value.lowerPowerEachW))} per lower resistor. Divider current is ${formatCurrent(Number(value.dividerCurrentA))}.`;
    };
    const outputs = new Map(
      Array.from(root.querySelectorAll<HTMLElement>('[data-output]')).map((element) => [element.dataset.output, element])
    );
    const errors = new Map(
      Array.from(root.querySelectorAll<HTMLElement>('[data-error-for]')).map((element) => [element.dataset.errorFor, element])
    );
    const copyButton = root.querySelector<HTMLButtonElement>('[data-copy-code]');
    let latestFirmwareCode = outputs.get('firmwareCode')?.textContent ?? '';

    const text = (key: string, value: string) => {
      const target = outputs.get(key);
      if (target) target.textContent = value;
    };

    const readInputs = () => {
      const get = <T extends HTMLInputElement | HTMLSelectElement>(selector: string) => root.querySelector<T>(selector);
      const topology = root.querySelector<HTMLInputElement>('input[name="topology"]:checked')?.value;

      return {
        maximumInputVoltage: Number(get<HTMLInputElement>('[data-input="maximumInputVoltage"]')?.value),
        adcReferenceVoltage: Number(get<HTMLInputElement>('[data-input="adcReferenceVoltage"]')?.value),
        adcResolutionBits: Number(get<HTMLSelectElement>('[data-input="adcResolutionBits"]')?.value) as 8 | 10 | 12 | 14,
        resistorSeries: get<HTMLSelectElement>('[data-input="resistorSeries"]')?.value as 'E24' | 'E96',
        resistorSize: get<HTMLSelectElement>('[data-input="resistorSize"]')?.value as '0402' | '0603' | '0805' | '1206' | '1210',
        upperResistorCount: Math.round(Number(get<HTMLInputElement>('[data-input="upperResistorCount"]')?.value)),
        topology: topology as 'single-lower' | 'parallel-lower'
      };
    };

    const setErrors = (messages: Partial<Record<string, string>>) => {
      errors.forEach((element, key) => {
        const message = messages[key ?? ''];
        element.textContent = message ?? '';
        element.hidden = !message;
      });
    };

    const renderChecks = (checks: ReturnType<typeof calculateVoltageSensingDesign>['checks']) => {
      const target = outputs.get('checks');
      if (!target) return;
      target.innerHTML = checks
        .map(
          (check) => `<div class="engineering-check engineering-check--${check.status}">
            <span>${check.status}</span>
            <div>
              <strong>${checkLabels[locale][check.messageCode]}</strong>
              <p>${renderCheckDetail(check)}</p>
            </div>
          </div>`
        )
        .join('');
    };

    const update = () => {
      const inputs = readInputs();
      const fieldErrors: Partial<Record<string, string>> = {};
      if (!(inputs.maximumInputVoltage > 0)) fieldErrors.maximumInputVoltage = textLabels[locale].vinError;
      if (!(inputs.adcReferenceVoltage > 0)) fieldErrors.adcReferenceVoltage = textLabels[locale].vrefError;
      if (!Number.isInteger(inputs.upperResistorCount) || inputs.upperResistorCount < 1 || inputs.upperResistorCount > 30) {
        fieldErrors.upperResistorCount = textLabels[locale].countError;
      }
      setErrors(fieldErrors);
      if (Object.keys(fieldErrors).length > 0) return;

      try {
        const result = calculateVoltageSensingDesign(inputs);
        const overallStatusCode = result.checks.some((check) => check.status === 'fail')
          ? 'fail'
          : result.checks.some((check) => check.status === 'review')
            ? 'review'
            : 'pass';
        const overallStatus = textLabels[locale][overallStatusCode];
        const lowerCount = inputs.topology === 'parallel-lower' ? 2 : 1;
        const rating = resistorPackageRatings[inputs.resistorSize];
        const statusPill = outputs.get('overallStatus');

        text('overallStatus', overallStatus);
        statusPill?.classList.remove('tool-check-pill--pass', 'tool-check-pill--review', 'tool-check-pill--fail');
        statusPill?.classList.add(`tool-check-pill--${overallStatusCode}`);
        text('upperString', `${inputs.upperResistorCount} × ${formatResistance(result.upperEachOhms)}`);
        text('upperDetail', `${textLabels[locale].upperTotal}: ${formatResistance(result.upperTotalOhms)}`);
        text('lowerBranch', `${lowerCount} × ${formatResistance(result.lowerEachOhms)}`);
        text(
          'lowerDetail',
          inputs.topology === 'parallel-lower'
            ? `${textLabels[locale].parallelEquivalent}: ${formatResistance(result.lowerEquivalentOhms)}`
            : `${textLabels[locale].equivalent}: ${formatResistance(result.lowerEquivalentOhms)}`
        );
        text('flowInput', formatVoltage(inputs.maximumInputVoltage));
        text('flowAdc', `${result.adcVoltage.toFixed(3)} V ADC`);
        text('flowCode', `${result.adcCode} / ${result.adcMaxCode}`);
        text('adcUtilization', `${(result.adcUtilization * 100).toFixed(1)}%`);
        text('scalingRatio', `${result.scalingRatio.toFixed(1)} : 1`);
        text('nominalAccuracy', `${result.nominalAccuracyPercent.toFixed(3)}%`);
        text('valueFitError', `${textLabels[locale].deviation}: ${result.valueFitErrorPercent >= 0 ? '+' : ''}${result.valueFitErrorPercent.toFixed(3)}%`);
        text('inputResolution', formatResolution(result.inputResolutionVPerCount));
        text('dividerCurrent', formatCurrent(result.dividerCurrentA));
        text('dividerPower', formatPower(result.dividerPowerW));
        text('formulaText', `${textLabels[locale].conversion}: Vin = ADC code × ${result.inputResolutionVPerCount.toFixed(8)} V.`);
        text('firmwareCode', result.firmwareCode);
        text(
          'ratingNote',
          `${textLabels[locale].ratingNote} ${inputs.resistorSize} ${textLabels[locale].values}: ${formatPower(rating.powerW)} and ${rating.workingVoltageV} V.`
        );
        latestFirmwareCode = result.firmwareCode;
        renderChecks(result.checks);
      } catch {
        setErrors({ upperResistorCount: textLabels[locale].noCombination });
      }
    };

    root.querySelectorAll('input, select').forEach((control) => {
      control.addEventListener('input', update);
      control.addEventListener('change', update);
    });

    copyButton?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(latestFirmwareCode);
        copyButton.textContent = textLabels[locale].copied;
      } catch {
        copyButton.textContent = textLabels[locale].copyFailed;
      }
      window.setTimeout(() => {
        copyButton.textContent = textLabels[locale].copy;
      }, 1200);
    });

    update();
  }
</script>
