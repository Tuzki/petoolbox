---
import RelatedToolCard from './RelatedToolCard.astro';
import type { ToolInfo } from '@/lib/tools';

type Props = {
  primaryTool: ToolInfo | null;
  relatedTools: ToolInfo[];
  compact?: boolean;
};

const { primaryTool, relatedTools, compact = false } = Astro.props;
---

<section class:list={['related-tools', { 'related-tools--compact': compact }]} aria-labelledby={compact ? 'mobile-tool-title' : 'tools-title'}>
  <h2 id={compact ? 'mobile-tool-title' : 'tools-title'}>Tools for This Design</h2>
  <div class="related-tools__list">
    {primaryTool && <RelatedToolCard tool={primaryTool} primary />}
    {relatedTools.map((tool) => <RelatedToolCard tool={tool} />)}
  </div>
</section>
