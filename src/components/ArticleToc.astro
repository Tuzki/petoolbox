---
import type { MarkdownHeading } from 'astro';
import type { Locale } from '@/lib/i18n/config';
import { getMessages } from '@/lib/i18n/messages';

type Props = {
  headings: MarkdownHeading[];
  locale: Locale;
  mobile?: boolean;
};

const { headings, locale, mobile = false } = Astro.props;
const label = getMessages(locale).pages.articles.tocLabel;
const tocItems = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

{tocItems.length > 0 && (
  mobile ? (
    <details class="article-toc article-toc--mobile">
      <summary>{label}</summary>
      <ol>
        {tocItems.map((heading) => (
          <li class={`article-toc__item article-toc__item--h${heading.depth}`}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ol>
    </details>
  ) : (
    <nav class="article-toc" aria-label={label}>
      <h2>{label}</h2>
      <ol>
        {tocItems.map((heading) => (
          <li class={`article-toc__item article-toc__item--h${heading.depth}`}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ol>
    </nav>
  )
)}
