---
import type { MarkdownHeading } from 'astro';

type Props = {
  headings: MarkdownHeading[];
  mobile?: boolean;
};

const { headings, mobile = false } = Astro.props;
const tocItems = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

{tocItems.length > 0 && (
  mobile ? (
    <details class="article-toc article-toc--mobile">
      <summary>On this page</summary>
      <ol>
        {tocItems.map((heading) => (
          <li class={`article-toc__item article-toc__item--h${heading.depth}`}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ol>
    </details>
  ) : (
    <nav class="article-toc" aria-label="On this page">
      <h2>On this page</h2>
      <ol>
        {tocItems.map((heading) => (
          <li class={`article-toc__item article-toc__item--h${heading.depth}`}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ol>
    </nav>
  )
)}
