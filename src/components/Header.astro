---
import { site } from '@/lib/site';
import { languageNavigation, primaryNavigation, toolsMenuSections, isActivePath } from '@/data/navigation';
import '@/styles/navigation.css';

const currentPath = Astro.url.pathname;
const toolsNav = primaryNavigation[0];
const directNavItems = primaryNavigation.slice(1);
const toolsActive = isActivePath(currentPath, toolsNav.href)
  || currentPath.startsWith('/topology-designers/')
  || currentPath.startsWith('/magnetics/')
  || currentPath.startsWith('/control/')
  || currentPath.startsWith('/simulation/');
---

<header class="site-header" data-site-header>
  <div class="site-header__inner">
    <a class="site-header__brand" href="/" aria-label="PE Toolbox home">
      <svg class="site-header__mark" viewBox="0 0 44 32" aria-hidden="true" focusable="false">
        <path d="M3 18h7l3-8 6 16 5-20 5 12h12" />
        <circle cx="10" cy="18" r="2" />
        <circle cx="41" cy="18" r="2" />
      </svg>
      <span>{site.name}</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary navigation">
      <div class:list={['site-nav__item', 'site-nav__item--has-menu', { 'site-nav__item--active': toolsActive }]} data-nav-item>
        <a
          class:list={['site-nav__link', { 'site-nav__link--active': toolsActive }]}
          href={toolsNav.href}
          aria-current={toolsActive && currentPath === toolsNav.href ? 'page' : undefined}
        >
          {toolsNav.label}
        </a>
        <button
          class="site-nav__toggle"
          type="button"
          aria-label="Toggle Tools menu"
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="mega-tools"
          data-menu-toggle
        >
          <span aria-hidden="true">▾</span>
        </button>
        <div class="mega-menu mega-menu--tools" id="mega-tools" data-menu-panel hidden>
          <div class="mega-menu__grid">
            {toolsMenuSections.map((section) => (
              <section class="mega-menu__section" aria-labelledby={`mega-tools-${section.label.toLowerCase().replaceAll(' ', '-')}`}>
                <h2 id={`mega-tools-${section.label.toLowerCase().replaceAll(' ', '-')}`}>{section.label}</h2>
                <ul>
                  {section.links.map((link) => (
                    <li>
                      <a class="mega-menu__entry" href={link.href}>
                        <span>{link.label}</span>
                        {link.status && <span class="status-pill">{link.status}</span>}
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </div>
      </div>

      {directNavItems.map((item) => (
        <a
          class:list={['site-nav__link', { 'site-nav__link--active': isActivePath(currentPath, item.href) }]}
          href={item.href}
          aria-current={isActivePath(currentPath, item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="site-header__language" aria-label="Language">
      <span class="language-link language-link--active" aria-current="true">{languageNavigation[0].label}</span>
      <span aria-hidden="true">|</span>
      <span class="language-link language-link--disabled" aria-disabled="true" title={languageNavigation[1].title}>{languageNavigation[1].label}</span>
    </div>

    <button
      class="mobile-menu-button"
      type="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-navigation"
      data-mobile-menu-button
    >
      <span aria-hidden="true">☰</span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-navigation" aria-label="Mobile navigation" data-mobile-nav hidden>
    <div class="mobile-nav__inner">
      <div class="mobile-nav__group">
        <div class="mobile-nav__row">
          <a href="/tools/" class="mobile-nav__link" data-mobile-link>Tools</a>
          <button
            class="mobile-nav__toggle"
            type="button"
            aria-label="Toggle Tools"
            aria-expanded="false"
            aria-controls="mobile-tools"
            data-mobile-submenu-toggle
          >
            <span aria-hidden="true">+</span>
          </button>
        </div>
        <div class="mobile-nav__submenu" id="mobile-tools" hidden>
          {toolsMenuSections.flatMap((section) => section.links).map((link) => (
            <a class="mobile-nav__subitem" href={link.href} data-mobile-link>
              <span>{link.label}</span>
              {link.status && <span class="status-pill">{link.status}</span>}
            </a>
          ))}
        </div>
      </div>
      {directNavItems.map((item) => (
        <a class="mobile-nav__standalone" href={item.href} data-mobile-link>{item.label}</a>
      ))}
      <div class="mobile-nav__language" aria-label="Language">
        <span class="language-link language-link--active" aria-current="true">{languageNavigation[0].label}</span>
        <span aria-hidden="true">|</span>
        <span class="language-link language-link--disabled" aria-disabled="true" title={languageNavigation[1].title}>{languageNavigation[1].label}</span>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector('[data-site-header]');

  if (header) {
    const desktopItems = Array.from(header.querySelectorAll('[data-nav-item]'));
    const mobileButton = header.querySelector<HTMLButtonElement>('[data-mobile-menu-button]');
    const mobileNav = header.querySelector<HTMLElement>('[data-mobile-nav]');
    let closeTimer: number | undefined;
    let openDesktopItem: Element | null = null;
    let pointerFocusGuard = false;

    const closeDesktopMenu = (item: Element | null) => {
      const panel = item?.querySelector<HTMLElement>('[data-menu-panel]');
      const toggle = item?.querySelector<HTMLButtonElement>('[data-menu-toggle]');
      if (!panel || !toggle) return;
      panel.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
      item?.removeAttribute('data-open-source');
      item?.classList.remove('site-nav__item--open');
      if (openDesktopItem === item) openDesktopItem = null;
    };

    const closeAllDesktopMenus = () => {
      desktopItems.forEach((item) => closeDesktopMenu(item));
    };

    const openDesktopMenu = (item: Element, source = 'passive') => {
      const panel = item.querySelector<HTMLElement>('[data-menu-panel]');
      const toggle = item.querySelector<HTMLButtonElement>('[data-menu-toggle]');
      if (!panel || !toggle) return;
      if (closeTimer) window.clearTimeout(closeTimer);
      desktopItems.forEach((candidate) => {
        if (candidate !== item) closeDesktopMenu(candidate);
      });
      panel.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      item.setAttribute('data-open-source', source);
      item.classList.add('site-nav__item--open');
      openDesktopItem = item;
    };

    desktopItems.forEach((item) => {
      const toggle = item.querySelector('[data-menu-toggle]');
      const panel = item.querySelector('[data-menu-panel]');
      if (!toggle || !panel) return;

      item.addEventListener('mouseenter', () => openDesktopMenu(item));
      item.addEventListener('mouseleave', () => {
        closeTimer = window.setTimeout(() => closeDesktopMenu(item), 160);
      });
      toggle.addEventListener('pointerdown', () => {
        pointerFocusGuard = true;
        window.setTimeout(() => {
          pointerFocusGuard = false;
        }, 0);
      });
      item.addEventListener('focusin', () => {
        if (!pointerFocusGuard) openDesktopMenu(item);
      });
      item.addEventListener('focusout', () => {
        closeTimer = window.setTimeout(() => {
          if (!item.contains(document.activeElement)) closeDesktopMenu(item);
        }, 160);
      });
      toggle.addEventListener('click', (event) => {
        event.stopPropagation();
        if (toggle.getAttribute('aria-expanded') === 'true' && item.getAttribute('data-open-source') === 'click') {
          closeDesktopMenu(item);
        } else {
          openDesktopMenu(item, 'click');
        }
      });
    });

    const resetMobileSubmenus = () => {
      header.querySelectorAll<HTMLButtonElement>('[data-mobile-submenu-toggle]').forEach((button) => {
        button.setAttribute('aria-expanded', 'false');
        const icon = button.querySelector('span');
        if (icon) icon.textContent = '+';
      });
      header.querySelectorAll<HTMLElement>('.mobile-nav__submenu').forEach((submenu) => {
        submenu.hidden = true;
      });
    };

    const closeMobileMenu = () => {
      if (!mobileButton || !mobileNav) return;
      mobileNav.hidden = true;
      mobileButton.setAttribute('aria-expanded', 'false');
      header.classList.remove('site-header--mobile-open');
      resetMobileSubmenus();
    };

    mobileButton?.addEventListener('click', (event) => {
      if (!mobileButton || !mobileNav) return;
      event.stopPropagation();
      const willOpen = mobileButton.getAttribute('aria-expanded') !== 'true';
      mobileNav.hidden = !willOpen;
      mobileButton.setAttribute('aria-expanded', String(willOpen));
      header.classList.toggle('site-header--mobile-open', willOpen);
      if (!willOpen) resetMobileSubmenus();
      closeAllDesktopMenus();
    });

    header.querySelectorAll('[data-mobile-submenu-toggle]').forEach((button) => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('aria-controls');
        const submenu = targetId ? header.querySelector<HTMLElement>(`#${targetId}`) : null;
        if (!submenu) return;
        const willOpen = button.getAttribute('aria-expanded') !== 'true';
        submenu.hidden = !willOpen;
        button.setAttribute('aria-expanded', String(willOpen));
        const icon = button.querySelector('span');
        if (icon) icon.textContent = willOpen ? '−' : '+';
      });
    });

    header.querySelectorAll('[data-mobile-link]').forEach((link) => {
      link.addEventListener('click', () => closeMobileMenu());
    });

    document.addEventListener('click', (event) => {
      if (!header.contains(event.target as Node | null)) {
        closeAllDesktopMenus();
        closeMobileMenu();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeAllDesktopMenus();
        closeMobileMenu();
      }
    });
  }
</script>
