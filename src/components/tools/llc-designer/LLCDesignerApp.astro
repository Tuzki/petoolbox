---
// Compatibility component for the validated LLC runtime engine. Keep element
// IDs stable until the engine has broader typed integration tests.
import type { Locale } from '@/lib/i18n/config';

type Props = { locale: Locale };
const { locale } = Astro.props;
const zh = locale === 'zh';
---

<div data-llc-designer-root data-locale={locale}>
  <div class="llc-shell">
    <header class="llc-hero">
      <div>
        <p class="llc-eyebrow">{zh ? '拓扑设计工具' : 'Topology Designers'}</p>
        <h1>{zh ? 'LLC 谐振变换器设计工具' : 'LLC Resonant Converter Designer'}</h1>
        <p>
          {zh
            ? '在输入电压和负载角点上搜索谐振腔候选设计，并检查频率范围、运行模式、设计裕量、状态平面轨迹和时域波形。'
            : 'Search resonant-tank candidates across input-voltage and load corners, then review frequency range, operating modes, design margin, state-plane trajectories, and time-domain waveforms.'}
        </p>
      </div>
      <div class="llc-badges" aria-label="Analysis methods">
        <span>Trajectory-guided ODE</span>
        <span>{zh ? '状态平面分析' : 'State-plane analysis'}</span>
        <span>{zh ? '浏览器端计算' : 'Browser-based'}</span>
      </div>
    </header>

    <section class="llc-card llc-spec-card" aria-labelledby="llc-specifications">
      <div class="llc-section-head">
        <div>
          <p class="llc-section-kicker">{zh ? '步骤 1' : 'Step 1'}</p>
          <h2 id="llc-specifications">{zh ? '设计规格' : 'Specifications'}</h2>
        </div>
        <p>{zh ? '设置电气需求和候选搜索空间，默认设计网格保持不变。' : 'Set electrical requirements and the candidate search space without changing the default design grid.'}</p>
      </div>

      <div class="llc-spec-body">
        <div class="llc-spec-grid">
          <fieldset class="llc-group">
            <legend>{zh ? '电气规格' : 'Electrical Specifications'}</legend>
            <label>{zh ? '输入拓扑' : 'Input topology'}
              <select id="bridge">
                <option value="half" selected>Half bridge (Vin / 0)</option>
                <option value="full">Full bridge (+Vin / -Vin)</option>
              </select>
            </label>
            <label>{zh ? '整流拓扑' : 'Rectifier topology'}
              <select id="secondary">
                <option value="fullwave" selected>Full-wave rectifier</option>
                <option disabled>Full-bridge rectifier</option>
                <option disabled>Half-wave rectifier</option>
              </select>
            </label>
            <div class="llc-fields">
              <label>Vin,min [V]<input id="vinMin" type="number" value="360" step="1" /></label>
              <label>Vin,typ [V]<input id="vinTyp" type="number" value="380" step="1" /></label>
              <label>Vin,max [V]<input id="vinMax" type="number" value="410" step="1" /></label>
              <label>{zh ? '模型' : 'Model'}<input value={zh ? '理想开关 / 理想全波整流' : 'Ideal switches / ideal full-wave rectifier'} readonly /></label>
            </div>
          </fieldset>

          <fieldset class="llc-group">
            <legend>{zh ? '输出与负载' : 'Output and Load'}</legend>
            <div class="llc-fields">
              <label>{zh ? '输出电压 Vo [V]' : 'Output voltage Vo [V]'}<input id="vo" type="number" value="12" min="0.1" step="0.1" /></label>
              <label>{zh ? '额定输出电流 Io [A]' : 'Rated output current Io [A]'}<input id="io" type="number" value="55" min="0.1" step="0.1" /></label>
              <label>{zh ? '最小连续负载 [%]' : 'Minimum continuous load [%]'}<input id="lightLoad" type="number" value="20" min="1" max="100" step="1" /></label>
              <label>{zh ? '过载裕量 [%]' : 'Overload allowance [%]'}<input id="overload" type="number" value="30" min="0" max="100" step="1" /></label>
              <label>{zh ? '额定功率 [W]' : 'Rated power [W]'}<input id="power" readonly /></label>
              <label>{zh ? '额定负载 [ohm]' : 'Rated load [ohm]'}<input id="roNom" readonly /></label>
              <label class="llc-wide">{zh ? '运行点' : 'Operating points'}<input value={zh ? '3 个输入电压 x 轻载、满载、过载 = 9 个角点' : '3 input voltages x light, full, and overload = 9 corners'} readonly /></label>
            </div>
          </fieldset>

          <fieldset class="llc-group">
            <legend>Frequency Constraints</legend>
            <label>Resonant frequency f0 [kHz]<input id="f0" type="number" value="100" min="10" step="1" /></label>
            <div class="llc-range-row">
              <span>Minimum fs</span>
              <input id="fsMinRatio" type="range" min="20" max="100" step="1" value="30" />
            </div>
            <div id="fsMinDisplay" class="llc-range-value">30% · 30 kHz</div>
            <div class="llc-range-row">
              <span>Maximum fs</span>
              <input id="fsMaxRatio" type="range" min="100" max="300" step="1" value="250" />
            </div>
            <div id="fsMaxDisplay" class="llc-range-value">250% · 250 kHz</div>
            <p class="llc-note">Switching-frequency limits are set as a percentage of f0 and displayed in kHz.</p>
          </fieldset>

          <fieldset class="llc-group">
            <legend>{zh ? '搜索约束' : 'Search Constraints'}</legend>
            <div id="ratioFormula" class="llc-note">{zh ? '中心变压器匝比由典型输入电压和拓扑计算得到。' : 'The center transformer ratio is calculated from the typical input voltage and topology.'}</div>
            <div class="llc-ratio-pills">
              <span id="n1Display" class="llc-ratio-pill">n-2</span>
              <span id="n2Display" class="llc-ratio-pill">n-1</span>
              <span id="n3Display" class="llc-ratio-pill">n</span>
              <span id="n4Display" class="llc-ratio-pill">n+1</span>
              <span id="n5Display" class="llc-ratio-pill">n+2</span>
            </div>
            <p class="llc-note">{zh ? '自动生成五个变压器匝比候选。' : 'Five transformer-ratio candidates are generated automatically.'}</p>
            <div class="llc-fields">
              <label class="llc-wide">9 k = Lm / Lr candidates<input id="kList" value="3, 3.5, 4, 4.5, 5, 5.5, 6, 6.5, 7" /></label>
              <label class="llc-wide">13 Qnom candidates<input id="qList" value="0.200, 0.225, 0.250, 0.275, 0.300, 0.325, 0.350, 0.375, 0.400, 0.425, 0.450, 0.475, 0.500" /></label>
            </div>
            <p class="llc-note">{zh ? '默认搜索评估 5 x 9 x 13 = 585 个候选。' : 'The default search evaluates 5 x 9 x 13 = 585 candidates.'}</p>
          </fieldset>
        </div>

        <div class="llc-actions" aria-label="Design search controls">
          <button id="runBtn" class="llc-button llc-button--primary" type="button">{zh ? '运行设计搜索' : 'Run Design Search'}</button>
          <button id="cancelBtn" class="llc-button llc-button--danger" type="button" disabled>{zh ? '取消搜索' : 'Cancel Search'}</button>
          <div class="llc-progress-wrap">
            <div class="llc-progress-line"><div id="progressBar" class="llc-progress-bar"></div></div>
            <div id="progressText" class="llc-progress-text">{zh ? '准备评估 9 个运行点上的 585 个候选。' : 'Ready to evaluate 585 candidates across 9 operating points.'}</div>
          </div>
        </div>
      </div>
    </section>

    <section class="llc-card llc-summary-card" aria-labelledby="llc-search-summary">
      <div class="llc-section-head">
        <div>
          <p class="llc-section-kicker">{zh ? '步骤 2' : 'Step 2'}</p>
          <h2 id="llc-search-summary">{zh ? '搜索摘要' : 'Search Summary'}</h2>
        </div>
        <p>{zh ? '搜索完成后更新候选数量。' : 'Candidate counts update after the search completes.'}</p>
      </div>
      <div class="llc-summary-grid">
        <div class="llc-metric"><b>{zh ? '总数' : 'Total'}</b><strong id="mTotal">585</strong></div>
        <div class="llc-metric llc-metric--feasible"><b>{zh ? '可行' : 'Feasible'}</b><strong id="mFeasible">—</strong></div>
        <div class="llc-metric llc-metric--marginal"><b>{zh ? '临界' : 'Marginal'}</b><strong id="mMarginal">—</strong></div>
        <div class="llc-metric llc-metric--failed"><b>{zh ? '失败 / 数值异常' : 'Failed / Numerical'}</b><strong id="mFailed">—</strong></div>
        <div class="llc-metric"><b>{zh ? '运行时间' : 'Run time'}</b><strong id="mTime">—</strong></div>
      </div>
    </section>

    <section class="llc-card llc-table-card" aria-labelledby="llc-recommended-designs">
      <div class="llc-section-head">
        <div>
          <p class="llc-section-kicker">{zh ? '步骤 3' : 'Step 3'}</p>
          <h2 id="llc-recommended-designs">{zh ? '推荐设计' : 'Recommended Designs'}</h2>
        </div>
        <p>{zh ? '按最坏工况裕量和约束余量排序的候选。' : 'Top-ranked candidates by worst-case margin and constraint headroom.'}</p>
      </div>
      <div class="llc-table-wrap">
        <table>
          <thead>
            <tr>
              <th>{zh ? '排名 / 状态' : 'Rank / Status'}</th>
              <th>n</th>
              <th>k</th>
              <th>Qnom</th>
              <th>Lr [µH]</th>
              <th>Lm [µH]</th>
              <th>Cr [nF]</th>
              <th>{zh ? 'fs 范围 [kHz]' : 'fs range [kHz]'}</th>
              <th>Ir,pk [A]</th>
              <th>Ir,rms [A]</th>
              <th>VCr,pk [V]</th>
              <th>{zh ? '最差裕量' : 'Worst margin'}</th>
              <th>{zh ? '限制' : 'Limit'}</th>
            </tr>
          </thead>
          <tbody id="recommendBody"><tr><td colspan="13">{zh ? '运行设计搜索以查看推荐设计。' : 'Run the design search to view recommended designs.'}</td></tr></tbody>
        </table>
      </div>
    </section>

    <div class="llc-design-grid">
      <section class="llc-card" aria-labelledby="llc-selected-design">
        <div class="llc-section-head">
          <div>
            <p class="llc-section-kicker">{zh ? '步骤 4' : 'Step 4'}</p>
            <h2 id="llc-selected-design">{zh ? '当前设计' : 'Selected Design'}</h2>
          </div>
          <p>{zh ? '查看当前候选及其限制裕量。' : 'Review the active candidate and its limiting margin.'}</p>
        </div>
        <div id="selectedPanel" class="llc-side-body"><div class="llc-empty">{zh ? '运行设计搜索以选择候选。' : 'Run the design search to select a candidate.'}</div></div>
      </section>

      <section class="llc-card" aria-labelledby="llc-ratio-overview">
        <div class="llc-section-head">
          <div>
            <p class="llc-section-kicker">{zh ? '步骤 5' : 'Step 5'}</p>
            <h2 id="llc-ratio-overview">{zh ? '变压器匝比概览' : 'Transformer-ratio Overview'}</h2>
          </div>
          <p>{zh ? '比较五个自动生成匝比候选的可行区域。' : 'Compare feasible regions across the five generated ratio candidates.'}</p>
        </div>
        <div id="ratioOverview" class="llc-overview-grid">
          <div class="llc-empty">{zh ? '运行设计搜索以比较五个变压器匝比候选的可行区域。' : 'Run the design search to compare the feasible regions of five transformer-ratio candidates.'}</div>
        </div>
      </section>
    </div>

    <section class="llc-card" aria-labelledby="llc-candidate-space">
      <div class="llc-section-head">
        <div>
          <p class="llc-section-kicker">{zh ? '步骤 6' : 'Step 6'}</p>
          <h2 id="llc-candidate-space">{zh ? '候选空间' : 'Candidate Space'}</h2>
          <p class="llc-head-note">{zh ? '每个单元格表示当前变压器匝比下的一组 k 和 Q 组合。' : 'Each cell represents one k and Q combination for the active transformer ratio.'}</p>
        </div>
        <div class="llc-matrix-toolbar">
          <span id="activeRatioLabel" class="llc-ratio-label">n = —</span>
          <select id="matrixMetric">
            <option value="margin">{zh ? '最坏工况裕量' : 'Worst-case margin'}</option>
            <option value="fsmax">{zh ? '最高所需频率' : 'Maximum required frequency'}</option>
            <option value="ipk">{zh ? '最差 Ir,pk' : 'Worst Ir,pk'}</option>
            <option value="irms">{zh ? '最差 Ir,rms' : 'Worst Ir,rms'}</option>
            <option value="vcrpk">{zh ? '最差 VCr,pk' : 'Worst VCr,pk'}</option>
            <option value="comm">{zh ? '最小换流电流' : 'Minimum commutation current'}</option>
          </select>
        </div>
      </div>
      <div class="llc-matrix-wrap"><div id="matrix" class="llc-matrix"></div></div>
      <div class="llc-legend">
        <span><i class="llc-dot feasible"></i>{zh ? '可行' : 'Feasible'}</span>
        <span><i class="llc-dot marginal"></i>{zh ? '临界' : 'Marginal'}</span>
        <span><i class="llc-dot failed"></i>{zh ? '失败' : 'Failed'}</span>
        <span><i class="llc-dot numerical"></i>{zh ? '数值异常' : 'Numerical issue'}</span>
        <span>{zh ? '限制：F↑ 高频，F↓ 低频，I 电流，V 电压，Z 换流，N 数值。' : 'Limits: F↑ high frequency, F↓ low frequency, I current, V voltage, Z commutation, N numerical.'}</span>
      </div>
    </section>

    <section class="llc-card llc-table-card" aria-labelledby="llc-operating-points">
      <div class="llc-section-head">
        <div>
          <p class="llc-section-kicker">{zh ? '步骤 7' : 'Step 7'}</p>
          <h2 id="llc-operating-points">{zh ? '运行点' : 'Operating Points'}</h2>
        </div>
        <p>{zh ? '选择任一运行点以更新状态平面和时域视图。' : 'Select any operating point to update the state-plane and time-domain views.'}</p>
      </div>
      <div class="llc-table-wrap">
        <table>
          <thead>
            <tr>
              <th>{zh ? '运行点' : 'Operating point'}</th>
              <th>Vin [V]</th>
              <th>{zh ? '负载' : 'Load'}</th>
              <th>fs [kHz]</th>
              <th>fs/f0</th>
              <th>{zh ? '控制分支' : 'Control branch'}</th>
              <th>Ir,pk [A]</th>
              <th>Ir,rms [A]</th>
              <th>VCr,pk [V]</th>
              <th>{zh ? '换流电流 [A]' : 'Commutation current [A]'}</th>
              <th>{zh ? '自由谐振区间' : 'Free interval'}</th>
              <th>ODE residual</th>
              <th>{zh ? '结果' : 'Result'}</th>
            </tr>
          </thead>
          <tbody id="cornerBody"><tr><td colspan="13">{zh ? '选择候选设计以查看运行点。' : 'Select a candidate design to inspect operating points.'}</td></tr></tbody>
        </table>
      </div>
    </section>

    <section class="llc-advanced" aria-labelledby="llc-advanced-analysis">
      <div class="llc-advanced-head">
        <div>
          <p class="llc-section-kicker">{zh ? '步骤 8' : 'Step 8'}</p>
          <h2 id="llc-advanced-analysis">{zh ? '深度分析' : 'Advanced Analysis'}</h2>
        </div>
        <p>{zh ? '使用图表检查所选设计的增益包络、运行模式、状态轨迹和波形。' : 'Use the plots to inspect gain envelope, operating mode, state trajectory, and waveforms for the selected design.'}</p>
      </div>

      <section class="llc-card llc-table-card" aria-labelledby="llc-gain-envelope">
        <div class="llc-section-head">
          <div>
            <h3 id="llc-gain-envelope">{zh ? '增益包络和所需开关频率范围' : 'Gain Envelope and Required Switching-Frequency Range'}</h3>
            <p class="llc-head-note">{zh ? '包络显示调节每个运行条件所需的开关频率范围。' : 'The envelope shows the switching-frequency range required to regulate each operating condition.'}</p>
          </div>
          <div class="llc-plot-tools"><button id="curveBtn" class="llc-button llc-button--secondary" type="button" disabled>{zh ? '计算增益包络' : 'Calculate Gain Envelope'}</button></div>
        </div>
        <div id="curveSummary" class="llc-envelope-summary">
          <div class="llc-envelope-chip"><b>{zh ? '目标增益范围' : 'Target gain range'}</b><span>—</span></div>
          <div class="llc-envelope-chip"><b>{zh ? '所需 fs 范围' : 'Required fs range'}</b><span>—</span></div>
          <div class="llc-envelope-chip"><b>{zh ? '低频裕量' : 'Low-frequency margin'}</b><span>—</span></div>
          <div class="llc-envelope-chip"><b>{zh ? '高频裕量' : 'High-frequency margin'}</b><span>—</span></div>
          <div class="llc-envelope-chip"><b>{zh ? '最紧角点' : 'Tightest corner'}</b><span>—</span></div>
        </div>
        <div class="llc-plot-body"><svg id="gainPlot" viewBox="0 0 1220 520"></svg></div>
        <p class="llc-plot-note">{zh ? '阴影带覆盖轻载到过载。目标增益线映射输入电压范围，标记显示 9 个已求解的 ODE 运行点。' : 'The shaded band spans light load through overload. Target gain lines map the input-voltage range, and markers show the nine solved ODE operating points.'}</p>
      </section>

      <div class="llc-state-grid">
        <section class="llc-card" aria-labelledby="llc-state-plane">
          <div class="llc-section-head">
            <div>
              <h3 id="llc-state-plane">{zh ? '状态平面轨迹' : 'State-plane Trajectory'}</h3>
              <p id="stateHint" class="llc-head-note">{zh ? '选择运行点以显示 vCr-iLr 状态轨迹。' : 'Select an operating point to show the vCr-iLr state trajectory.'}</p>
            </div>
            <button id="waveBtn" class="llc-button llc-button--secondary" type="button" disabled>{zh ? '重新计算细节' : 'Recalculate Details'}</button>
          </div>
          <div class="llc-plot-body"><svg id="statePlot" viewBox="0 0 900 520"></svg></div>
          <div class="llc-mode-legend">
            <span><i class="llc-swatch" style="background:#2563eb"></i>{zh ? '正向整流钳位' : 'Forward rectifier clamp'}</span>
            <span><i class="llc-swatch" style="background:#f59e0b"></i>{zh ? '自由谐振' : 'Free resonance'}</span>
            <span><i class="llc-swatch" style="background:#7c3aed"></i>{zh ? '反向整流钳位' : 'Reverse rectifier clamp'}</span>
            <span><i class="llc-swatch" style="background:#111827"></i>{zh ? '开关切换' : 'Switching transition'}</span>
          </div>
        </section>
        <section class="llc-card" aria-labelledby="llc-mode-summary">
          <div class="llc-section-head">
            <div>
              <h3 id="llc-mode-summary">{zh ? '运行模式摘要' : 'Operating-mode Summary'}</h3>
            </div>
            <p>{zh ? '对所选角点的简要解释。' : 'Brief interpretation of the selected corner.'}</p>
          </div>
          <div id="stateSummary" class="llc-state-summary"><div class="llc-empty">{zh ? '选择有效运行点以查看模式摘要。' : 'Select a valid operating point to view the mode summary.'}</div></div>
        </section>
      </div>

      <section class="llc-card llc-table-card" aria-labelledby="llc-waveforms">
        <div class="llc-section-head">
          <div>
            <h3 id="llc-waveforms">{zh ? '时域波形' : 'Time-domain Waveforms'}</h3>
            <p id="waveHint" class="llc-head-note">{zh ? '选择运行点以显示三个开关周期的 ODE 波形。' : 'Select an operating point to show three switching periods of ODE waveforms.'}</p>
          </div>
        </div>
        <div class="llc-plot-body"><svg id="wavePlot" viewBox="0 0 1220 520"></svg></div>
        <p class="llc-plot-note">{zh ? '波形与状态平面视图使用同一个已求解运行点。换流电流是理想化指标，不包含 Coss、死区时间或寄生参数。' : 'The waveforms use the same solved operating point as the state-plane view. Commutation current is an idealized proxy and does not include Coss, dead time, or parasitics.'}</p>
      </section>
    </section>

    <p class="llc-model-note">{zh ? '模型边界：理想开关、理想整流器、恒定输出电压、连续频率调制，不包含 burst/skip 运行和寄生参数。' : 'Model boundary: ideal switches, ideal rectifier, constant output voltage, continuous frequency modulation, no burst or skip operation, and no parasitic elements.'}</p>
  </div>
</div>

<script>
  import "../../../scripts/llc-designer/bootstrap";
</script>
