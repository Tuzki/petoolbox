---
import type { ToolInfo } from '@/lib/tools';
import { formatToolStatus } from '@/lib/tools';
import type { Locale } from '@/lib/i18n/config';

type Props = {
  tool: ToolInfo;
  locale: Locale;
  primary?: boolean;
};

const { tool, locale, primary = false } = Astro.props;
const label = primary ? (locale === 'zh' ? '主要工具' : 'Primary Tool') : formatToolStatus(tool.status, locale);
---

{tool.status === 'available' && tool.href ? (
  <a class:list={['tool-card', { 'tool-card--primary': primary }]} href={tool.href}>
    <span class="tool-card__label">{label}</span>
    <strong>{tool.title}</strong>
    <span>{tool.description}</span>
  </a>
) : (
  <article class:list={['tool-card', 'tool-card--planned', { 'tool-card--primary': primary }]} aria-label={`${tool.title} ${formatToolStatus(tool.status, locale)} tool`}>
    <span class="tool-card__label">{label}</span>
    <strong>{tool.title}</strong>
    <span>{tool.description}</span>
  </article>
)}
