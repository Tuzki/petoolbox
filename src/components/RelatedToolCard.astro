---
import type { ToolInfo } from '@/lib/tools';
import { formatToolStatus } from '@/lib/tools';

type Props = {
  tool: ToolInfo;
  primary?: boolean;
};

const { tool, primary = false } = Astro.props;
const label = primary ? 'Primary Tool' : formatToolStatus(tool.status);
---

{tool.status === 'available' && tool.href ? (
  <a class:list={['tool-card', { 'tool-card--primary': primary }]} href={tool.href}>
    <span class="tool-card__label">{label}</span>
    <strong>{tool.title}</strong>
    <span>{tool.description}</span>
  </a>
) : (
  <article class:list={['tool-card', 'tool-card--planned', { 'tool-card--primary': primary }]} aria-label={`${tool.title} ${formatToolStatus(tool.status)} tool`}>
    <span class="tool-card__label">{label}</span>
    <strong>{tool.title}</strong>
    <span>{tool.description}</span>
  </article>
)}
