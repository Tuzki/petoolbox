---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import ArticleToc from '@/components/ArticleToc.astro';
import RelatedTools from '@/components/RelatedTools.astro';
import { getTool, getTools } from '@/lib/tools';
import '@/styles/article.css';

type Props = {
  article: CollectionEntry<'articles'>;
  headings: MarkdownHeading[];
  relatedArticles: CollectionEntry<'articles'>[];
};

const { article, headings, relatedArticles } = Astro.props;
const primaryTool = getTool(article.data.primaryTool);
const relatedTools = getTools(article.data.relatedTools);
const published = article.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const updated = article.data.updatedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title={article.data.title} description={article.data.description} pathname={`/articles/${article.slug}/`}>
  <main class="article-shell">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/articles/">Articles</a>
      <span aria-hidden="true">/</span>
      <span>{article.data.title}</span>
    </nav>

    <header class="article-hero">
      <p class="article-hero__category">{article.data.category.replace('-', ' ')}</p>
      <h1>{article.data.title}</h1>
      <p class="article-hero__description">{article.data.description}</p>
      <div class="article-meta">
        <span>PE Toolbox Editorial</span>
        <span>Published {published}</span>
        <span>Updated {updated}</span>
      </div>
      {primaryTool && <div class="article-mobile-tool"><RelatedTools primaryTool={primaryTool} relatedTools={[]} compact /></div>}
      <ArticleToc headings={headings} mobile />
    </header>

    <div class="article-grid">
      <article class="article-content">
        <slot />
      </article>
      <aside class="article-sidebar" aria-label="Article sidebar">
        <div class="article-sidebar__sticky">
          <ArticleToc headings={headings} />
          <RelatedTools primaryTool={primaryTool} relatedTools={relatedTools} />
        </div>
      </aside>
    </div>

    {relatedArticles.length > 0 && (
      <section class="related-articles" aria-labelledby="related-articles-title">
        <h2 id="related-articles-title">Related Articles</h2>
        <div class="related-articles__list">
          {relatedArticles.map((relatedArticle) => (
            <a class="related-article-card" href={`/articles/${relatedArticle.slug}/`}>
              <span>{relatedArticle.data.category.replace('-', ' ')}</span>
              <strong>{relatedArticle.data.title}</strong>
              <small>{relatedArticle.data.description}</small>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>
