---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import ArticleToc from '@/components/ArticleToc.astro';
import RelatedTools from '@/components/RelatedTools.astro';
import { getTool, getTools } from '@/lib/tools';
import { articleCategoryLabel, articleHref, articleSlug, formatArticleDate, type ArticleEntry } from '@/lib/articles';
import { getMessages } from '@/lib/i18n/messages';
import type { Locale } from '@/lib/i18n/config';
import '@/styles/article.css';

type Props = {
  article: CollectionEntry<'articles'>;
  headings: MarkdownHeading[];
  relatedArticles: CollectionEntry<'articles'>[];
  locale: Locale;
};

const { article, headings, relatedArticles, locale } = Astro.props;
const t = getMessages(locale);
const primaryTool = getTool(article.data.primaryTool, locale);
const relatedTools = getTools(article.data.relatedTools, locale);
const published = formatArticleDate(article.data.publishedAt, locale);
const updated = formatArticleDate(article.data.updatedAt, locale);
const categoryLabel = articleCategoryLabel(article.data.category, locale);
---

<BaseLayout title={article.data.title} description={article.data.description} pathname={`/articles/${articleSlug(article as ArticleEntry)}/`} locale={locale}>
  <main class="article-shell">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={`/${locale}/`}>{t.site.breadcrumbs.home}</a>
      <span aria-hidden="true">/</span>
      <a href={`/${locale}/articles/`}>{t.pages.articles.title}</a>
      <span aria-hidden="true">/</span>
      <span>{article.data.title}</span>
    </nav>

    <header class="article-hero">
      <p class="article-hero__category">{categoryLabel}</p>
      <h1>{article.data.title}</h1>
      <p class="article-hero__description">{article.data.description}</p>
      <div class="article-meta">
        <span>{t.pages.articles.editorial}</span>
        <span>{t.pages.articles.published} {published}</span>
        <span>{t.pages.articles.updated} {updated}</span>
      </div>
      {primaryTool && <div class="article-mobile-tool"><RelatedTools primaryTool={primaryTool} relatedTools={[]} locale={locale} compact /></div>}
      <ArticleToc headings={headings} locale={locale} mobile />
    </header>

    <div class="article-grid">
      <article class="article-content">
        <slot />
      </article>
      <aside class="article-sidebar" aria-label="Article sidebar">
        <div class="article-sidebar__sticky">
          <ArticleToc headings={headings} locale={locale} />
          <RelatedTools primaryTool={primaryTool} relatedTools={relatedTools} locale={locale} />
        </div>
      </aside>
    </div>

    {relatedArticles.length > 0 && (
      <section class="related-articles" aria-labelledby="related-articles-title">
        <h2 id="related-articles-title">{t.pages.articles.related}</h2>
        <div class="related-articles__list">
          {relatedArticles.map((relatedArticle) => (
            <a class="related-article-card" href={articleHref(relatedArticle as ArticleEntry, locale)}>
              <span>{articleCategoryLabel(relatedArticle.data.category, locale)}</span>
              <strong>{relatedArticle.data.title}</strong>
              <small>{relatedArticle.data.description}</small>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>
